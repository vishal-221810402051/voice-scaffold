{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VoiceScaffoldInfraAST",
  "type": "object",
  "required": ["project_name", "template", "services"],
  "additionalProperties": false,

  "properties": {
    "project_name": {
      "type": "string",
      "minLength": 3
    },

    "template": {
      "type": "string",
      "enum": ["realtime_data_stack", "api_microservice_stack"]
    },

    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "port"],
        "additionalProperties": false,

        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "port": {
            "type": "integer",
            "minimum": 1024,
            "maximum": 65535
          }
        }
      }
    }
  }
}
